---
layout: base.njk
---
<main class="article-page"><article class="article-shell"><a class="btn" href="/videos.html">← Πίσω στα Βίντεο</a><p class="date" style="margin-top:30px">{{ displayDate }}</p><h1 style="font-size:clamp(38px,6vw,72px);line-height:1;letter-spacing:-.055em;margin:.2em 0">{{ title }}</h1>{% if youtube %}<div class="video-embed panel"><iframe src="{{ youtube }}" title="{{ title }}" loading="lazy" allowfullscreen></iframe></div>{% elif thumbnail %}<img class="article-hero-img" src="{{ thumbnail }}" alt="{{ title }}" />{% endif %}</article></main>