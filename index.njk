<section class="section"><div class="wrap"><div class="section-head"><div><p class="eyebrow">Νέα</p><h2>Επικαιρότητα, Απόψεις, Δράσεις</h2></div><a class="btn" href="/news.html">Όλα τα νέα</a></div><div class="grid cards home-news-grid">
{% set posts = collections.articles | reverse %}
{% for post in posts %}
{% if loop.index0 < 6 %}
<a class="card reveal news-card {% if loop.first %}news-feature{% endif %}" href="{{ post.url }}">{% if post.data.image %}<div class="card-media"><img alt="{{ post.data.title }}" loading="lazy" src="{{ post.data.image }}"/></div>{% endif %}<span class="date">{{ post.data.displayDate | default(post.date) }}</span><h3>{{ post.data.title }}</h3><span class="read-more">Διαβάστε περισσότερα →</span></a>
{% endif %}
{% endfor %}
</div></div></section>
<section class="section"><div class="wrap"><div class="section-head"><div><p class="eyebrow">Βίντεο - Συνεντεύξεις</p><h2>Βίντεο</h2></div><a class="btn" href="/videos.html">Όλα τα βίντεο</a></div><div class="grid video-grid">
{% set vids = collections.videos | reverse %}
{% for video in vids %}
{% if loop.index0 < 3 %}
<a class="card reveal" href="{{ video.url }}">{% if video.data.thumbnail %}<div class="card-media"><img alt="{{ video.data.title }}" loading="lazy" src="{{ video.data.thumbnail }}"/></div>{% endif %}<span class="date">{{ video.data.displayDate | default(video.data.date) }}</span><h3>{{ video.data.title }}</h3></a>
{% endif %}
{% endfor %}
</div></div></section>
